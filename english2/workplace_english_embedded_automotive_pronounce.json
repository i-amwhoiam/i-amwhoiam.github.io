  "items": [
    { "id": "core-01", "category": "core", "en": "I have finished this task.", "cn": "我已经完成这个任务。", "tags": ["basic", "speaking"] },
    { "id": "core-02", "category": "core", "en": "I am working on the CAN test.", "cn": "我正在做 CAN 测试。", "tags": ["status", "progress"] },
    { "id": "core-03", "category": "core", "en": "I found an issue with the signal value.", "cn": "我发现信号值有一个问题。", "tags": ["issue", "report"] },
    { "id": "core-04", "category": "core", "en": "Let me confirm my understanding.", "cn": "我确认一下我的理解。", "tags": ["clarify", "meeting"] },
    { "id": "core-05", "category": "core", "en": "Could you help check this issue?", "cn": "你能帮忙检查这个问题吗？", "tags": ["help", "issue"] },
    { "id": "core-06", "category": "core", "en": "I am not fully sure yet.", "cn": "我还不是完全确定。", "tags": ["uncertain", "clarify"] },
    { "id": "core-07", "category": "core", "en": "Next, I will collect the log.", "cn": "下一步我会收集日志。", "tags": ["next-step", "debug"] },
    { "id": "core-08", "category": "core", "en": "The issue is still open.", "cn": "问题还没关闭。", "tags": ["status", "issue"] },
    { "id": "core-09", "category": "core", "en": "The actual result is different from the expected result.", "cn": "实际结果和预期结果不同。", "tags": ["test", "result"] },
    { "id": "core-10", "category": "core", "en": "I will keep you updated.", "cn": "我会持续更新你。", "tags": ["update", "communication"] },

    { "id": "meeting-01", "category": "meeting", "en": "What is the current status?", "cn": "当前状态是什么？", "tags": ["meeting", "status"] },
    { "id": "meeting-02", "category": "meeting", "en": "Are we on track?", "cn": "我们进度正常吗？", "tags": ["schedule", "risk"] },
    { "id": "meeting-03", "category": "meeting", "en": "Any blockers?", "cn": "有阻塞点吗？", "tags": ["blocker", "meeting"] },
    { "id": "meeting-04", "category": "meeting", "en": "Could you give a quick update?", "cn": "你能快速更新一下进展吗？", "tags": ["update", "meeting"] },
    { "id": "meeting-05", "category": "meeting", "en": "This item is still open.", "cn": "这个事项还没关闭。", "tags": ["status", "task"] },
    { "id": "meeting-06", "category": "meeting", "en": "We need more time to analyze the root cause.", "cn": "我们需要更多时间分析根因。", "tags": ["debug", "risk"] },
    { "id": "meeting-07", "category": "meeting", "en": "The main risk is the unstable test environment.", "cn": "主要风险是测试环境不稳定。", "tags": ["risk", "test"] },
    { "id": "meeting-08", "category": "meeting", "en": "I will update it by EOD.", "cn": "我会在今天下班前更新。", "tags": ["deadline", "status"] },
    { "id": "meeting-09", "category": "meeting", "en": "Let's take this offline.", "cn": "我们会后单独讨论这个。", "tags": ["follow-up", "meeting"] },
    { "id": "meeting-10", "category": "meeting", "en": "What is the next step?", "cn": "下一步是什么？", "tags": ["next-step", "meeting"] },

    { "id": "daily-01", "category": "daily", "en": "Hi, do you have a few minutes?", "cn": "你好，你现在有几分钟吗？", "tags": ["chat", "daily"] },
    { "id": "daily-02", "category": "daily", "en": "I need your input on this requirement.", "cn": "这个需求我需要你的意见。", "tags": ["requirement", "help"] },
    { "id": "daily-03", "category": "daily", "en": "Could you repeat that?", "cn": "你能重复一下吗？", "tags": ["hearing", "clarify"] },
    { "id": "daily-04", "category": "daily", "en": "Could you say that more slowly?", "cn": "你能说慢一点吗？", "tags": ["hearing", "clarify"] },
    { "id": "daily-05", "category": "daily", "en": "Could you type it in the chat?", "cn": "你能把它打在聊天里吗？", "tags": ["chat", "help"] },
    { "id": "daily-06", "category": "daily", "en": "I will check and get back to you.", "cn": "我检查后回复你。", "tags": ["response", "follow-up"] },
    { "id": "daily-07", "category": "daily", "en": "Please use the latest build.", "cn": "请使用最新版本。", "tags": ["build", "test"] },
    { "id": "daily-08", "category": "daily", "en": "I need more information.", "cn": "我需要更多信息。", "tags": ["clarify", "help"] },
    { "id": "daily-09", "category": "daily", "en": "Let's align on the next steps.", "cn": "我们对齐一下下一步。", "tags": ["alignment", "meeting"] },
    { "id": "daily-10", "category": "daily", "en": "I will follow up later.", "cn": "我稍后继续跟进。", "tags": ["follow-up", "status"] },

    { "id": "embedded-01", "category": "embedded", "en": "The board does not boot.", "cn": "板子无法启动。", "tags": ["board", "boot"] },
    { "id": "embedded-02", "category": "embedded", "en": "The firmware update failed.", "cn": "固件更新失败。", "tags": ["firmware", "update"] },
    { "id": "embedded-03", "category": "embedded", "en": "The interrupt is not triggered.", "cn": "中断没有触发。", "tags": ["interrupt", "driver"] },
    { "id": "embedded-04", "category": "embedded", "en": "The callback is not called.", "cn": "回调函数没有被调用。", "tags": ["callback", "driver"] },
    { "id": "embedded-05", "category": "embedded", "en": "The task stops running.", "cn": "任务停止运行。", "tags": ["task", "rtos"] },
    { "id": "embedded-06", "category": "embedded", "en": "The CPU load is too high.", "cn": "CPU 负载太高。", "tags": ["performance", "cpu"] },
    { "id": "embedded-07", "category": "embedded", "en": "The memory usage is too high.", "cn": "内存使用太高。", "tags": ["memory", "performance"] },
    { "id": "embedded-08", "category": "embedded", "en": "The initialization order is wrong.", "cn": "初始化顺序错误。", "tags": ["init", "sequence"] },
    { "id": "embedded-09", "category": "embedded", "en": "The buffer may overflow.", "cn": "缓冲区可能溢出。", "tags": ["buffer", "safety"] },
    { "id": "embedded-10", "category": "embedded", "en": "The clock configuration is incorrect.", "cn": "时钟配置不正确。", "tags": ["clock", "configuration"] },

    { "id": "automotive-01", "category": "automotive", "en": "The ECU does not respond.", "cn": "ECU 没有响应。", "tags": ["ecu", "diagnostic"] },
    { "id": "automotive-02", "category": "automotive", "en": "The CAN message is missing.", "cn": "CAN 报文丢失。", "tags": ["can", "message"] },
    { "id": "automotive-03", "category": "automotive", "en": "The signal value is incorrect.", "cn": "信号值不正确。", "tags": ["signal", "dbc"] },
    { "id": "automotive-04", "category": "automotive", "en": "The message cycle time is unstable.", "cn": "报文周期不稳定。", "tags": ["cycle-time", "can"] },
    { "id": "automotive-05", "category": "automotive", "en": "The diagnostic request timed out.", "cn": "诊断请求超时。", "tags": ["uds", "timeout"] },
    { "id": "automotive-06", "category": "automotive", "en": "The DTC is not stored.", "cn": "DTC 没有存储。", "tags": ["dtc", "fault"] },
    { "id": "automotive-07", "category": "automotive", "en": "The flashing process failed.", "cn": "刷写过程失败。", "tags": ["flashing", "reprogramming"] },
    { "id": "automotive-08", "category": "automotive", "en": "The ECU enters sleep mode too late.", "cn": "ECU 进入休眠太晚。", "tags": ["sleep", "power"] },
    { "id": "automotive-09", "category": "automotive", "en": "The wake-up behavior is incorrect.", "cn": "唤醒行为不正确。", "tags": ["wake-up", "power"] },
    { "id": "automotive-10", "category": "automotive", "en": "The gateway does not forward the message.", "cn": "网关没有转发报文。", "tags": ["gateway", "network"] },

    { "id": "testing-01", "category": "testing", "en": "The test passed.", "cn": "测试通过。", "tags": ["test", "result"] },
    { "id": "testing-02", "category": "testing", "en": "The test failed.", "cn": "测试失败。", "tags": ["test", "result"] },
    { "id": "testing-03", "category": "testing", "en": "I can reproduce it on my side.", "cn": "我这边可以复现它。", "tags": ["reproduce", "bug"] },
    { "id": "testing-04", "category": "testing", "en": "I cannot reproduce it on my side.", "cn": "我这边无法复现它。", "tags": ["reproduce", "bug"] },
    { "id": "testing-05", "category": "testing", "en": "The issue happens every time.", "cn": "这个问题每次都会发生。", "tags": ["frequency", "bug"] },
    { "id": "testing-06", "category": "testing", "en": "The issue happens sometimes.", "cn": "这个问题有时会发生。", "tags": ["frequency", "bug"] },
    { "id": "testing-07", "category": "testing", "en": "We need more logs.", "cn": "我们需要更多日志。", "tags": ["log", "debug"] },
    { "id": "testing-08", "category": "testing", "en": "The root cause is not clear yet.", "cn": "根因还不清楚。", "tags": ["rca", "debug"] },
    { "id": "testing-09", "category": "testing", "en": "This looks like a regression issue.", "cn": "这看起来像回归问题。", "tags": ["regression", "bug"] },
    { "id": "testing-10", "category": "testing", "en": "The workaround is to reset the device.", "cn": "临时方案是复位设备。", "tags": ["workaround", "device"] },

    { "id": "debug-01", "category": "debug", "en": "The log shows that the device reset at 10:32.", "cn": "日志显示设备在 10:32 复位。", "tags": ["log", "reset"] },
    { "id": "debug-02", "category": "debug", "en": "The trace shows that the message was not sent.", "cn": "跟踪记录显示报文没有发送。", "tags": ["trace", "can"] },
    { "id": "debug-03", "category": "debug", "en": "The issue seems related to timing.", "cn": "这个问题看起来和时序有关。", "tags": ["timing", "analysis"] },
    { "id": "debug-04", "category": "debug", "en": "The issue seems related to memory corruption.", "cn": "这个问题看起来和内存破坏有关。", "tags": ["memory", "analysis"] },
    { "id": "debug-05", "category": "debug", "en": "The timestamp does not match.", "cn": "时间戳对不上。", "tags": ["timestamp", "trace"] },
    { "id": "debug-06", "category": "debug", "en": "The issue only happens after a power cycle.", "cn": "这个问题只在重新上电后发生。", "tags": ["power", "reproduce"] },
    { "id": "debug-07", "category": "debug", "en": "I found an error code in the log.", "cn": "我在日志里发现了一个错误码。", "tags": ["error", "log"] },
    { "id": "debug-08", "category": "debug", "en": "We need more detailed logs.", "cn": "我们需要更详细的日志。", "tags": ["log", "detail"] },
    { "id": "debug-09", "category": "debug", "en": "The root cause is an incorrect initialization order.", "cn": "根因是初始化顺序错误。", "tags": ["rca", "init"] },
    { "id": "debug-10", "category": "debug", "en": "The permanent fix is to update the state machine logic.", "cn": "永久修复方案是更新状态机逻辑。", "tags": ["fix", "state-machine"] },

    { "id": "communication-01", "category": "communication", "en": "Hi team, I found an issue during the regression test.", "cn": "团队好，我在回归测试中发现了一个问题。", "tags": ["email", "bug"] },
    { "id": "communication-02", "category": "communication", "en": "Please find the log attached.", "cn": "请查看附件中的日志。", "tags": ["email", "log"] },
    { "id": "communication-03", "category": "communication", "en": "Could you help check the log?", "cn": "你能帮忙看一下日志吗？", "tags": ["help", "log"] },
    { "id": "communication-04", "category": "communication", "en": "I will update the ticket.", "cn": "我会更新问题单。", "tags": ["ticket", "update"] },
    { "id": "communication-05", "category": "communication", "en": "Thanks for your support.", "cn": "感谢你的支持。", "tags": ["polite", "email"] },
    { "id": "communication-06", "category": "communication", "en": "I need confirmation from the system team.", "cn": "我需要系统团队确认。", "tags": ["confirm", "requirement"] },
    { "id": "communication-07", "category": "communication", "en": "I will rerun the test after the new build is available.", "cn": "新版本可用后我会重新执行测试。", "tags": ["test", "build"] },
    { "id": "communication-08", "category": "communication", "en": "Please review my merge request.", "cn": "请评审我的合并请求。", "tags": ["review", "code"] },
    { "id": "communication-09", "category": "communication", "en": "I will get back to you later.", "cn": "我稍后回复你。", "tags": ["follow-up", "chat"] },
    { "id": "communication-10", "category": "communication", "en": "Please let me know your feedback.", "cn": "请告诉我你的反馈。", "tags": ["feedback", "email"] }
  ]
}
